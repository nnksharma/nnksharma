             "\[IndentingNewLine]", 
             RowBox[{"t", "=", 
              RowBox[{"Table", "[", 
               RowBox[{"j", ",", 
                RowBox[{"{", 
                 RowBox[{"j", ",", 
                  RowBox[{"-", "2"}], ",", "2", ",", 
                  FractionBox[
                   RowBox[{
                    RowBox[{"2", "n"}], "+", "1"}], "200"]}], "}"}]}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"tt1", " ", "=", " ", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"t", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", 
                  RowBox[{"irho24", "[", 
                   RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "1", ",", " ", 
                  RowBox[{"Length", "[", "table0", "]"}]}], "}"}]}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"posFilter", "=", " ", 
              RowBox[{"Select", "[", 
               RowBox[{"tt1", ",", " ", 
                RowBox[{
                 RowBox[{"0", "<=", " ", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "<=", "2"}], " ", "&"}]}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"negFilter", "=", " ", 
              RowBox[{"Select", "[", 
