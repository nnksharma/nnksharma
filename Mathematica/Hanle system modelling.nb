Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Generating", " ", "plots", " ", "for", " ", "Separation", " ", "and", " ",
     "relative", " ", "Amplitude", " ", 
    RowBox[{"v", "/", "s"}], " ", "transverse", " ", "B", " ", "for", " ", 
    "the", " ", "resonance", " ", "at", " ", "different", " ", "power", " ", 
    "of", " ", "Probe", " ", "beam"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParallelDo", "[", "\[IndentingNewLine]", 
