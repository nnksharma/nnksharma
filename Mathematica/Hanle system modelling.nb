                RowBox[{"[", 
                 RowBox[{"1", ",", "2"}], "]"}], "]"}], "-", 
               RowBox[{
                RowBox[{"MinimalBy", "[", 
                 RowBox[{"posFilter", ",", " ", "Last"}], "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
            "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"FWHM", " ", "=", " ", 
               RowBox[{
