                   RowBox[{"[", "1", "]"}], "]"}], "<=", "0"}], " ", "&"}]}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"diff", " ", "=", " ", 
              RowBox[{
               RowBox[{
                RowBox[{"MinimalBy", "[", 
